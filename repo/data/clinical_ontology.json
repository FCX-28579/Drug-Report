{
  "schema_version": "1.0",
  "last_reviewed": "2026-05-07",
  "_doc": "All cancer-specific clinical knowledge lives here. Code MUST NOT hard-code cancer aliases, anti-aliases, chemo regimens, OS thresholds, or prior-therapy classes. Adding a new cancer = add an entry here, no code change required.",

  "_extension_guide": {
    "to_support_new_cancer_X": [
      "1. Add entry to cancers.X with: aliases (synonyms), anti_aliases (histologic distinctions to exclude), median_os_at_line_n (for GoC trigger), default_imaging_modality.",
      "2. Add chemo_regimens entries that are first-line or commonly-used in cancer X.",
      "3. Add prior_therapy_classes entries for the targeted-therapy classes used in cancer X.",
      "4. Add SoC entries to data/soc_benchmarks.json for cancer X × line × molecular subtype.",
      "5. (Optional but recommended) Add risk_profiles to data/risk_taxonomy.json for cancer-specific mechanism risks.",
      "6. (Optional) Add efficacy snapshots to data/efficacy_database.json for trials/drugs in cancer X."
    ]
  },

